@model medicalapp.Models.Appointment

@{
    ViewData["Title"] = "Appointment Details - MediCloud";
    Layout = "_Layout";
}

<div class="appointment-details-container">
    <div class="container">
        <div class="header-section">
            <h2>📋 Appointment Details</h2>
            <p class="text-muted">Detailed view of your booked consultation.</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <div class="details-card">
            <!-- Header status row -->
            <div class="details-header">
                <div class="ref-num">
                    <span class="label">Reference ID:</span>
                    <span class="value">#@Model.Id</span>
                </div>
                <div class="status-wrapper">
                    <span class="status-badge @Model.Status.ToLower()">@Model.Status</span>
                </div>
            </div>

            <!-- Doctor Information Info Card -->
            <div class="info-section">
                <h3>👨‍⚕️ Consultant Doctor</h3>
                <div class="doctor-profile-card">
                    <div class="doctor-avatar-circle">
                        <i class="fas fa-user-md"></i>
                    </div>
                    <div class="doctor-detail-text">
                        <h4>Dr. @Model.Doctor?.User?.FirstName @Model.Doctor?.User?.LastName</h4>
                        <p class="specialization">@Model.Doctor?.Specialization</p>
                    </div>
                </div>
            </div>

            <!-- Schedule Info Card -->
            <div class="info-section">
                <h3>📅 Date & Time</h3>
                <div class="grid-details">
                    <div class="detail-item">
                        <span class="item-label"><i class="fas fa-calendar-day text-primary"></i> Date</span>
                        <span class="item-value">@Model.AppointmentDate.ToString("dd MMMM yyyy (dddd)")</span>
                    </div>
                    <div class="detail-item">
                        <span class="item-label"><i class="fas fa-clock text-primary"></i> Time</span>
                        <span class="item-value">@Model.StartTime.ToString(@"hh\:mm") - @Model.EndTime.ToString(@"hh\:mm")</span>
                    </div>
                </div>
            </div>

            <!-- Visit Details Info Card -->
            <div class="info-section">
                <h3>📝 Consultation Request</h3>
                <div class="symptom-box">
                    <div class="symptom-row">
                        <strong>Reason for Visit:</strong>
                        <p>@(string.IsNullOrEmpty(Model.ReasonForVisit) ? "Not specified" : Model.ReasonForVisit)</p>
                    </div>
                    <div class="symptom-row">
                        <strong>Reported Symptoms:</strong>
                        <p>@(string.IsNullOrEmpty(Model.Symptoms) ? "No symptoms reported" : Model.Symptoms)</p>
                    </div>
                </div>
            </div>

            <!-- Invoice billing Info Card -->
            <div class="info-section">
                <h3>💳 Billing & Payment</h3>
                <div class="grid-details">
                    <div class="detail-item">
                        <span class="item-label">Consultation Fee</span>
                        <span class="item-value price">RM @Model.TotalAmount</span>
                    </div>
                    <div class="detail-item">
                        <span class="item-label">Payment Status</span>
                        <span class="item-value payment-status @(Model.IsPaid ? "paid" : "unpaid")">
                            <i class="fas @(Model.IsPaid ? "fa-check-circle" : "fa-exclamation-circle")"></i>
                            @(Model.IsPaid ? "Paid" : "Unpaid")
                        </span>
                    </div>
                </div>
            </div>

            <!-- Action buttons -->
            <div class="action-footer">
                <a href="@Url.Action("Appointments")" class="btn btn-outline">
                    <i class="fas fa-arrow-left"></i> Back to Appointments
                </a>
                
                @if (Model.Status == "Pending" || Model.Status == "Confirmed")
                {
                    <form id="cancel-form" asp-action="CancelAppointment" asp-route-id="@Model.Id" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="button" class="btn btn-danger" onclick="showConfirm('Cancel Appointment', 'Are you sure you want to cancel this appointment? This action cannot be undone.', () => document.getElementById('cancel-form').submit())">
                            <i class="fas fa-times-circle"></i> Cancel Appointment
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .appointment-details-container { padding: 40px 0; background: #f8f9fa; min-height: 80vh; }
        .header-section { margin-bottom: 25px; }
        .header-section h2 { color: #003366; }
        
        .details-card {
            background: white;
            padding: 35px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            max-width: 700px;
            margin: 0 auto;
        }

        .details-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #eee;
            padding-bottom: 18px;
            margin-bottom: 25px;
        }
        .ref-num .label { color: #888; font-size: 0.9rem; }
        .ref-num .value { font-weight: 700; color: #003366; }
        
        .status-badge {
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
        }
        .status-badge.pending { background: #ffc107; color: #856404; }
        .status-badge.confirmed { background: #28a745; color: white; }
        .status-badge.completed { background: #6c757d; color: white; }
        .status-badge.cancelled { background: #dc3545; color: white; }

        .info-section { margin-bottom: 25px; }
        .info-section h3 {
            font-size: 1.1rem;
            color: #003366;
            margin-bottom: 12px;
            border-bottom: 1px solid #f1f1f1;
            padding-bottom: 8px;
        }

        .doctor-profile-card {
            display: flex;
            align-items: center;
            gap: 15px;
            background: #fdfdfd;
            border: 1px solid #eef1f6;
            padding: 15px;
            border-radius: 8px;
        }
        .doctor-avatar-circle {
            background: #eef5fc;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #0056a7;
            font-size: 1.4rem;
        }
        .doctor-detail-text h4 { margin: 0 0 3px 0; color: #333; }
        .doctor-detail-text p.specialization { margin: 0; color: #666; font-size: 0.9rem; }

        .grid-details {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 15px;
        }
        .detail-item {
            background: #fafbfc;
            border: 1px solid #f1f3f7;
            padding: 12px 15px;
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        .item-label { font-size: 0.8rem; color: #777; font-weight: 500; }
        .item-value { font-size: 0.95rem; font-weight: 600; color: #333; }
        .item-value.price { color: #0056a7; font-size: 1.1rem; }
        
        .payment-status { display: inline-flex; align-items: center; gap: 6px; }
        .payment-status.paid { color: #28a745; }
        .payment-status.unpaid { color: #dc3545; }

        .symptom-box {
            background: #fafbfc;
            border: 1px solid #f1f3f7;
            padding: 18px;
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }
        .symptom-row strong { color: #444; font-size: 0.9rem; display: block; margin-bottom: 5px; }
        .symptom-row p { margin: 0; font-size: 0.95rem; color: #666; line-height: 1.5; font-style: italic; }

        .action-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid #eee;
            padding-top: 25px;
            margin-top: 30px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .btn {
            padding: 10px 24px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            cursor: pointer;
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }
        .btn-outline { background: transparent; color: #0056a7; border: 1px solid #0056a7; }
        .btn-outline:hover { background: #eef5fc; }
        .btn-danger { background: #dc3545; color: white; }
        .btn-danger:hover { background: #bd2130; }

        .alert {
            padding: 12px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
        .alert-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .alert-danger { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    </style>
}
