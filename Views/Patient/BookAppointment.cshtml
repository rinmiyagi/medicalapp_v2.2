@model medicalapp.Models.ViewModels.BookAppointmentViewModel

@{
    ViewData["Title"] = "Book Appointment - MediCloud";
    Layout = "_Layout";
}

<div class="booking-container">
    <div class="container">
        <h2>📅 Book an Appointment</h2>
        <p class="text-muted">Select a doctor and choose your preferred date and time.</p>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

        <div class="booking-card">
            <form asp-action="BookAppointment" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="PackageName" />
                <input type="hidden" asp-for="PackagePrice" />

                <!-- Step 1: Select Doctor or Display Package -->
                @if (Model.PackagePrice.HasValue)
                {
                    <div class="form-step">
                        <h4>Selected Health Package</h4>
                        <div class="package-selected-card">
                            <div class="package-info-pill">
                                <i class="fas fa-heartbeat"></i>
                                <div>
                                    <div class="p-title">@Model.PackageName</div>
                                    <div class="p-price">RM @Model.PackagePrice?.ToString("N2")</div>
                                </div>
                            </div>
                            <p class="text-muted mt-2 mb-0" style="font-size: 0.85rem;"><i class="fas fa-info-circle"></i> Date and time selection is used to secure your slot at our health screening wellness center.</p>
                        </div>
                        <input type="hidden" asp-for="DoctorId" id="DoctorId" />
                    </div>
                }
                else
                {
                    <div class="form-step">
                        <h4>Step 1: Select Doctor</h4>
                        <div class="form-group">
                            <label asp-for="DoctorId"></label>
                            <select asp-for="DoctorId" asp-items="Model.Doctors" class="form-control" id="DoctorId">
                                <option value="">-- Select a Doctor --</option>
                            </select>
                            <span asp-validation-for="DoctorId" class="text-danger"></span>
                        </div>
                    </div>
                }

                <!-- Step 2: Select Date & Time -->
                <div class="form-step">
                    <h4>Step 2: Select Date & Time</h4>
                    <div class="form-group">
                        <label>Appointment Date</label>
                        <input id="AppointmentDatePicker" class="form-control" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        <small class="form-text text-muted">Please select your preferred date first.</small>
                        
                        @if (Model.AvailableDayNames != null && Model.AvailableDayNames.Any())
                        {
                            <div class="alert alert-info mt-2 py-2 px-3" style="font-size: 0.85rem; background: #eef5fc; border-color: #d0e3f5; color: #0056a7; border-radius: 8px;">
                                <i class="fas fa-calendar-alt me-1"></i> Available days for this service: 
                                <strong>@string.Join(", ", Model.AvailableDayNames)</strong>
                            </div>
                        }
                    </div>

                    <div class="form-group mt-3" id="slotSection" style="display: none;">
                        <label class="fw-bold d-block mb-2">Available Time Slots</label>
                        <div id="slotsContainer" class="d-flex flex-wrap gap-2">
                            <!-- Dynamic Slots Buttons -->
                        </div>
                        <input type="hidden" asp-for="AppointmentDate" id="AppointmentDateHidden" />
                        <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                    </div>
                </div>

                <!-- Step 3: Add Details -->
                <div class="form-step">
                    <h4>Step 3: Tell us about your visit</h4>
                    <div class="form-group">
                        <label asp-for="ReasonForVisit"></label>
                        <input asp-for="ReasonForVisit" class="form-control" placeholder="E.g., Chest pain, fever, checkup" />
                        <span asp-validation-for="ReasonForVisit" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Symptoms"></label>
                        <textarea asp-for="Symptoms" class="form-control" rows="3" placeholder="Describe your symptoms (optional)"></textarea>
                        <span asp-validation-for="Symptoms" class="text-danger"></span>
                    </div>
                </div>

                <!-- Summary -->
                <div class="form-step summary">
                    <h4>Appointment Summary</h4>
                    <div class="summary-grid">
                        <div class="summary-item">
                            <span class="summary-label">Consultation Fee:</span>
                            <span class="summary-value">RM <span id="feeDisplay">0.00</span></span>
                        </div>
                        <div class="summary-item">
                            <span class="summary-label">Tax (6%):</span>
                            <span class="summary-value">RM <span id="taxDisplay">0.00</span></span>
                        </div>
                        <div class="summary-item total">
                            <span class="summary-label">Total Amount:</span>
                            <span class="summary-value">RM <span id="totalDisplay">0.00</span></span>
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-check-circle"></i> Confirm Booking
                    </button>
                    <a href="@Url.Action("Dashboard")" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .booking-container {
            padding: 40px 0;
        }

        .booking-container h2 {
            color: #003366;
            margin-bottom: 5px;
        }

        .booking-card {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            margin-top: 25px;
            max-width: 700px;
        }

        .form-step {
            margin-bottom: 30px;
            padding-bottom: 25px;
            border-bottom: 1px solid #eee;
        }

        .form-step:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

        .form-step h4 {
            color: #003366;
            margin-bottom: 15px;
            font-size: 1.1rem;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-control {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
        }

        .form-control:focus {
            outline: none;
            border-color: #0056a7;
        }

        .form-text {
            color: #666;
            font-size: 0.85rem;
        }

        .summary {
            background: #f8f9fa;
            padding: 20px !important;
            border-radius: 10px;
            border-bottom: none !important;
        }

        .summary-grid {
            display: grid;
            gap: 10px;
        }

        .summary-item {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid #eee;
        }

        .summary-item.total {
            border-bottom: none;
            font-weight: 700;
            font-size: 1.1rem;
        }

        .summary-label { color: #666; }
        .summary-value { color: #003366; font-weight: 600; }
        .summary-item.total .summary-value { color: #0056a7; font-size: 1.3rem; }

        .form-actions {
            margin-top: 25px;
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .btn-lg {
            padding: 12px 30px;
            font-size: 1rem;
        }

        .alert {
            padding: 12px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .text-danger {
            color: #dc3545;
            font-size: 0.9rem;
        }

        .text-muted {
            color: #666;
        }

        .slot-btn {
            border: 1px solid #dee2e6;
            background-color: #fff;
            color: #495057;
            padding: 10px 16px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.2s ease;
            cursor: pointer;
        }
        .slot-btn:hover:not(:disabled) {
            border-color: #0056a7;
            color: #0056a7;
            background-color: #eef5fc;
        }
        .slot-btn.active {
            background-color: #0056a7 !important;
            border-color: #0056a7 !important;
            color: #fff !important;
        }
        .slot-btn:disabled {
            background-color: #e9ecef;
            border-color: #dee2e6;
            color: #adb5bd;
            cursor: not-allowed;
        }

        /* Health Screening Package Card UI */
        .package-selected-card {
            background: #f4f8fc;
            border: 1px solid #d0e3f5;
            padding: 20px;
            border-radius: 10px;
        }
        .package-info-pill {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .package-info-pill i {
            font-size: 2.2rem;
            color: #0056a7;
        }
        .package-info-pill .p-title {
            font-size: 1.2rem;
            font-weight: 700;
            color: #003366;
            display: block;
        }
        .package-info-pill .p-price {
            font-size: 1.1rem;
            font-weight: 600;
            color: #0056a7;
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const doctorSelect = document.getElementById("DoctorId");
            const datePicker = document.getElementById("AppointmentDatePicker");
            const slotSection = document.getElementById("slotSection");
            const slotsContainer = document.getElementById("slotsContainer");
            const hiddenDateInput = document.getElementById("AppointmentDateHidden");
            
            const feeDisplay = document.getElementById("feeDisplay");
            const taxDisplay = document.getElementById("taxDisplay");
            const totalDisplay = document.getElementById("totalDisplay");

            const isPackage = @(Model.PackagePrice.HasValue ? "true" : "false");
            const availableDays = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AvailableDaysOfWeek));
            let selectedTime = null;

            async function updateAvailableSlots() {
                const doctorId = doctorSelect.value;
                const dateVal = datePicker.value;

                if (!doctorId || !dateVal) {
                    slotSection.style.display = "none";
                    slotsContainer.innerHTML = "";
                    selectedTime = null;
                    hiddenDateInput.value = "";
                    return;
                }

                // Verify Day of Week against Doctor schedules (0=Sunday, 1=Monday... 6=Saturday)
                if (availableDays && availableDays.length > 0) {
                    const dateParts = dateVal.split('-');
                    const localDate = new Date(dateParts[0], dateParts[1] - 1, dateParts[2]);
                    const selectedDayOfWeek = localDate.getDay();

                    if (!availableDays.includes(selectedDayOfWeek)) {
                        slotSection.style.display = "block";
                        slotsContainer.innerHTML = '<span class="text-danger fw-bold"><i class="fas fa-exclamation-triangle"></i> The specialized doctor for this screening is not available on this day. Please select a different date.</span>';
                        selectedTime = null;
                        hiddenDateInput.value = "";
                        return;
                    }
                }

                try {
                    const response = await fetch(`/Patient/GetAvailableSlots?doctorId=${doctorId}&date=${dateVal}`);
                    if (response.ok) {
                        const slots = await response.json();
                        slotsContainer.innerHTML = "";
                        
                        if (slots && slots.length > 0) {
                            slots.forEach(slot => {
                                const btn = document.createElement("button");
                                btn.type = "button";
                                btn.className = "btn slot-btn";
                                btn.textContent = slot;
                                btn.dataset.time = slot;
                                
                                if (selectedTime === slot) {
                                    btn.classList.add("active");
                                }

                                btn.addEventListener("click", function () {
                                    document.querySelectorAll(".slot-btn").forEach(b => b.classList.remove("active"));
                                    btn.classList.add("active");
                                    selectedTime = slot;
                                    hiddenDateInput.value = `${dateVal}T${slot}:00`;
                                });

                                slotsContainer.appendChild(btn);
                            });
                        } else {
                            slotsContainer.innerHTML = '<span class="text-danger fw-bold">No available working hours found for this doctor on this day.</span>';
                        }
                        slotSection.style.display = "block";
                    }
                } catch (error) {
                    console.error("Error fetching slots:", error);
                }
            }

            async function updateFeeSummary() {
                if (isPackage) {
                    const fee = parseFloat("@(Model.PackagePrice ?? 0)");
                    const tax = fee * 0.06;
                    const total = fee + tax;

                    feeDisplay.textContent = fee.toFixed(2);
                    taxDisplay.textContent = tax.toFixed(2);
                    totalDisplay.textContent = total.toFixed(2);
                    return;
                }

                const doctorId = doctorSelect.value;
                if (!doctorId) {
                    feeDisplay.textContent = "0.00";
                    taxDisplay.textContent = "0.00";
                    totalDisplay.textContent = "0.00";
                    return;
                }

                try {
                    const response = await fetch(`/Patient/GetDoctorFee?doctorId=${doctorId}`);
                    if (response.ok) {
                        const data = await response.json();
                        const fee = parseFloat(data.fee);
                        const tax = fee * 0.06;
                        const total = fee + tax;

                        feeDisplay.textContent = fee.toFixed(2);
                        taxDisplay.textContent = tax.toFixed(2);
                        totalDisplay.textContent = total.toFixed(2);
                    }
                } catch (error) {
                    console.error("Fetch error:", error);
                }
            }

            if (!isPackage) {
                doctorSelect.addEventListener("change", function () {
                    updateFeeSummary();
                    updateAvailableSlots();
                });
            }
            
            datePicker.addEventListener("change", updateAvailableSlots);

            // Initial restore check
            if (isPackage || doctorSelect.value) {
                updateFeeSummary();
                
                if (isPackage) {
                    updateAvailableSlots();
                }

                if (hiddenDateInput.value) {
                    const dt = new Date(hiddenDateInput.value);
                    if (!isNaN(dt.getTime())) {
                        const yyyy = dt.getFullYear();
                        const mm = String(dt.getMonth() + 1).padStart(2, '0');
                        const dd = String(dt.getDate()).padStart(2, '0');
                        datePicker.value = `${yyyy}-${mm}-${dd}`;
                        
                        const hh = String(dt.getHours()).padStart(2, '0');
                        const min = String(dt.getMinutes()).padStart(2, '0');
                        selectedTime = `${hh}:${min}`;
                        
                        updateAvailableSlots();
                    }
                }
            }
        });
    </script>
}