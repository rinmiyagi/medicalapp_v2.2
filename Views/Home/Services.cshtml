@{
    ViewData["Title"] = "Our Services - MediCloud Hospital";
    Layout = "_Layout";
}

<section class="page-header">
    <div class="container">
        <h1>Our Services</h1>
        <p>Comprehensive healthcare services across multiple specialties</p>
    </div>
</section>

<section class="services-grid-section py-5">
    <div class="container">
        <div class="row g-4 mt-3">
            <!-- Cardiology -->
            <div class="col-12 col-md-6 col-lg-3">
                <div class="service-card h-100">
                    <i class="fas fa-heartbeat"></i>
                    <h3>Cardiology</h3>
                    <p>Diagnosis and treatment of heart conditions, including coronary artery disease, heart failure, and arrhythmias.</p>
                    <a href="#" class="service-link">Learn More →</a>
                </div>
            </div>
            <!-- Pediatrics -->
            <div class="col-12 col-md-6 col-lg-3">
                <div class="service-card h-100">
                    <i class="fas fa-child"></i>
                    <h3>Pediatrics</h3>
                    <p>Specialized medical care for infants, children, and adolescents, from routine check-ups to complex conditions.</p>
                    <a href="#" class="service-link">Learn More →</a>
                </div>
            </div>
            <!-- Orthopedics -->
            <div class="col-12 col-md-6 col-lg-3">
                <div class="service-card h-100">
                    <i class="fas fa-bone"></i>
                    <h3>Orthopedics</h3>
                    <p>Treatment of musculoskeletal conditions, including joint replacement, sports injuries, and spine surgery.</p>
                    <a href="#" class="service-link">Learn More →</a>
                </div>
            </div>
            <!-- Neurology -->
            <div class="col-12 col-md-6 col-lg-3">
                <div class="service-card h-100">
                    <i class="fas fa-brain"></i>
                    <h3>Neurology</h3>
                    <p>Diagnosis and treatment of neurological disorders, including stroke, epilepsy, Parkinson's, and Alzheimer's.</p>
                    <a href="#" class="service-link">Learn More →</a>
                </div>
            </div>
        </div>
    </div>
</section>