@{
    ViewData["Title"] = "Find a Doctor - MediCloud Hospital";
    Layout = "_Layout";
}

<section class="page-header">
    <div class="container">
        <h1>Find a Doctor</h1>
        <p>Search for our specialists by name, specialty, or location</p>
    </div>
</section>

<section class="search-section">
    <div class="container">
        <div class="search-box">
            <input type="text" placeholder="Search by name, specialty, or location..." id="doctorSearch" />
            <button onclick="searchDoctors()"><i class="fas fa-search"></i> Search</button>
        </div>
        <div class="filter-tags">
            <span class="filter-tag active">All</span>
            <span class="filter-tag">Cardiology</span>
            <span class="filter-tag">Pediatrics</span>
            <span class="filter-tag">Orthopedics</span>
            <span class="filter-tag">Neurology</span>
            <span class="filter-tag">Pulmonology</span>
        </div>
    </div>
</section>

<section class="doctor-grid-section">
    <div class="container">
        <div class="doctor-grid">
            <!-- Doctor Card 1 -->
            <div class="doctor-card">
                <div class="doctor-image">
                    <img src="/images/doctor-placeholder.jpg" alt="Dr. Siti Aminah" />
                </div>
                <div class="doctor-info">
                    <h3>Dr. Siti Aminah</h3>
                    <p class="specialty">Cardiology</p>
                    <p class="experience">12 years experience</p>
                    <div class="rating">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star-half-alt"></i>
                        <span>(127 reviews)</span>
                    </div>
                    <p class="location"><i class="fas fa-map-marker-alt"></i> KL Sentral</p>
                    <p class="fee">Consultation: RM 150</p>
                    <a href="#" class="btn btn-primary btn-block">Book Appointment</a>
                </div>
            </div>

            <!-- Doctor Card 2 -->
            <div class="doctor-card">
                <div class="doctor-image">
                    <img src="/images/doctor-placeholder.jpg" alt="Dr. Ahmad Fazli" />
                </div>
                <div class="doctor-info">
                    <h3>Dr. Ahmad Fazli</h3>
                    <p class="specialty">Cardiology</p>
                    <p class="experience">8 years experience</p>
                    <div class="rating">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <span>(89 reviews)</span>
                    </div>
                    <p class="location"><i class="fas fa-map-marker-alt"></i> TTDI</p>
                    <p class="fee">Consultation: RM 120</p>
                    <a href="#" class="btn btn-primary btn-block">Book Appointment</a>
                </div>
            </div>
        </div>
    </div>
</section>