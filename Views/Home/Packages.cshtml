@{
    ViewData["Title"] = "Health Screening Packages - MediCloud Hospital";
    Layout = "_Layout";
}

<section class="page-header">
    <div class="container">
        <h1>Health Screening Packages</h1>
        <p>Affordable and comprehensive health screenings for early detection and prevention</p>
    </div>
</section>

<section class="packages-grid-section">
    <div class="container">
        <div class="package-grid">
            <div class="package-card featured">
                <span class="package-badge">Most Popular</span>
                <h3>Executive Wellness</h3>
                <p class="package-price">RM 499</p>
                <ul class="package-features">
                    <li><i class="fas fa-check-circle"></i> Complete Blood Count</li>
                    <li><i class="fas fa-check-circle"></i> Cholesterol & Diabetes Screening</li>
                    <li><i class="fas fa-check-circle"></i> Chest X-Ray</li>
                    <li><i class="fas fa-check-circle"></i> ECG</li>
                    <li><i class="fas fa-check-circle"></i> Specialist Consultation</li>
                </ul>
                <a href="#" class="btn btn-primary btn-block">Book Now</a>
            </div>
            <div class="package-card">
                <h3>Basic Health Check</h3>
                <p class="package-price">RM 199</p>
                <ul class="package-features">
                    <li><i class="fas fa-check-circle"></i> Blood Pressure Check</li>
                    <li><i class="fas fa-check-circle"></i> Blood Glucose Test</li>
                    <li><i class="fas fa-check-circle"></i> Cholesterol Test</li>
                    <li><i class="fas fa-check-circle"></i> BMI Assessment</li>
                </ul>
                <a href="#" class="btn btn-outline btn-block">Book Now</a>
            </div>
            <div class="package-card">
                <h3>Heart Screening</h3>
                <p class="package-price">RM 349</p>
                <ul class="package-features">
                    <li><i class="fas fa-check-circle"></i> Cardiac Risk Assessment</li>
                    <li><i class="fas fa-check-circle"></i> ECG</li>
                    <li><i class="fas fa-check-circle"></i> Stress Test</li>
                    <li><i class="fas fa-check-circle"></i> Lipid Profile</li>
                </ul>
                <a href="#" class="btn btn-outline btn-block">Book Now</a>
            </div>
        </div>
    </div>
</section>