@{
    ViewData["Title"] = "MediCloud Hospital - Your Health, Our Priority";
    Layout = "_Layout";
}

<!-- Hero Section -->
<section class="hero">
    <div class="hero-content">
        <h1>Your Health, Our Priority</h1>
        <p>Expert care you can trust. With multiple locations and a team of dedicated specialists, we're here for you and your family.</p>
        <div class="hero-buttons">
            <a href="@Url.Action("Packages")" class="btn btn-primary btn-lg">Book Appointment</a>
            <a href="@Url.Action("Services")" class="btn btn-outline-light btn-lg">View Our Services</a>
        </div>
    </div>
</section>

<!-- Department Section -->
<section class="departments-section">
    <div class="container">
        <h2 class="section-title">Our Medical Departments</h2>
        <p class="section-subtitle">Leading healthcare across a wide range of specialties</p>
        <div class="department-grid">
            <div class="dept-card">
                <i class="fas fa-heart"></i>
                <h3>Cardiology</h3>
                <p>Comprehensive heart care from diagnosis to treatment and recovery.</p>
                <a href="#" class="dept-link">Learn More →</a>
            </div>
            <div class="dept-card">
                <i class="fas fa-baby"></i>
                <h3>Pediatrics</h3>
                <p>Specialized care for children from birth through adolescence.</p>
                <a href="#" class="dept-link">Learn More →</a>
            </div>
            <div class="dept-card">
                <i class="fas fa-bone"></i>
                <h3>Orthopedics</h3>
                <p>Treatment for conditions of the bones, joints, and spine.</p>
                <a href="#" class="dept-link">Learn More →</a>
            </div>
            <div class="dept-card">
                <i class="fas fa-brain"></i>
                <h3>Neurology</h3>
                <p>Advanced care for disorders of the brain and nervous system.</p>
                <a href="#" class="dept-link">Learn More →</a>
            </div>
            <div class="dept-card">
                <i class="fas fa-lungs"></i>
                <h3>Pulmonology</h3>
                <p>Diagnosis and treatment of respiratory conditions and lung diseases.</p>
                <a href="#" class="dept-link">Learn More →</a>
            </div>
            <div class="dept-card">
                <i class="fas fa-robot"></i>
                <h3>Robotic Surgery</h3>
                <p>Minimally invasive surgery using the latest robotic technology.</p>
                <a href="#" class="dept-link">Learn More →</a>
            </div>
        </div>
    </div>
</section>

<!-- Health Screening Packages -->
<section class="packages-section">
    <div class="container">
        <h2 class="section-title">Health Screening Packages</h2>
        <p class="section-subtitle">Affordable and comprehensive health screenings to keep you healthy</p>
        <div class="package-grid">
            <div class="package-card featured">
                <span class="package-badge">Most Popular</span>
                <h3>Executive Wellness</h3>
                <p class="package-price">RM 499</p>
                <ul class="package-features">
                    <li><i class="fas fa-check-circle"></i> Complete Blood Count</li>
                    <li><i class="fas fa-check-circle"></i> Cholesterol & Diabetes Screening</li>
                    <li><i class="fas fa-check-circle"></i> Chest X-Ray</li>
                    <li><i class="fas fa-check-circle"></i> ECG</li>
                    <li><i class="fas fa-check-circle"></i> Specialist Consultation</li>
                </ul>
                <a href="@Url.Action("Packages")" class="btn btn-primary btn-block">Book Now</a>
            </div>
            <div class="package-card">
                <h3>Basic Health Check</h3>
                <p class="package-price">RM 199</p>
                <ul class="package-features">
                    <li><i class="fas fa-check-circle"></i> Blood Pressure Check</li>
                    <li><i class="fas fa-check-circle"></i> Blood Glucose Test</li>
                    <li><i class="fas fa-check-circle"></i> Cholesterol Test</li>
                    <li><i class="fas fa-check-circle"></i> BMI Assessment</li>
                </ul>
                <a href="@Url.Action("Packages")" class="btn btn-outline btn-block">Book Now</a>
            </div>
            <div class="package-card">
                <h3>Heart Screening</h3>
                <p class="package-price">RM 349</p>
                <ul class="package-features">
                    <li><i class="fas fa-check-circle"></i> Cardiac Risk Assessment</li>
                    <li><i class="fas fa-check-circle"></i> ECG</li>
                    <li><i class="fas fa-check-circle"></i> Stress Test</li>
                    <li><i class="fas fa-check-circle"></i> Lipid Profile</li>
                </ul>
                <a href="@Url.Action("Packages")" class="btn btn-outline btn-block">Book Now</a>
            </div>
        </div>
    </div>
</section>