<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/style.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
</head>
<body>

    <!-- Navigation -->
    <nav class="navbar">
        <div class="container">
            <div class="nav-brand">
                <i class="fas fa-hospital-alt"></i>
                <span>MediCloud</span>
                <span class="hospital-badge">Hospital</span>
            </div>
            <ul class="nav-links">
                <li><a href="@Url.Action("Index", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">Home</a></li>
                <li><a href="@Url.Action("Doctors", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Doctors" ? "active" : "")">Find a Doctor</a></li>
                <li><a href="@Url.Action("Services", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Services" ? "active" : "")">Our Services</a></li>
                <li><a href="@Url.Action("Packages", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Packages" ? "active" : "")">Health Packages</a></li>
                <li><a href="@Url.Action("Contact", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Contact" ? "active" : "")">Contact Us</a></li>
            </ul>
            <div class="nav-right">
                <span class="header-date">
                    <i class="fas fa-calendar-alt"></i>
                    @DateTime.Now.ToString("dddd, dd MMM yyyy")
                </span>
                <div class="nav-buttons">
                    @if (User.Identity.IsAuthenticated)
                    {
                        @if (User.IsInRole("Patient"))
                        {
                            <a href="@Url.Action("Dashboard", "Patient")" class="btn btn-outline" style="margin-right: 8px;">
                                <i class="fas fa-user-md"></i> Dashboard
                            </a>
                            <a href="@Url.Action("Appointments", "Patient")" class="btn btn-outline" style="margin-right: 8px;">
                                <i class="fas fa-calendar-check"></i> Appointments
                            </a>
                            <a href="@Url.Action("MyInvoices", "Invoice")" class="btn btn-outline" style="margin-right: 8px;">
                                <i class="fas fa-file-invoice"></i> My Invoices
                            </a>
                        }
                        @if (User.IsInRole("Doctor"))
                        {
                            <a href="@Url.Action("Dashboard", "Doctor")" class="btn btn-outline" style="margin-right: 8px;">
                                <i class="fas fa-stethoscope"></i> Dashboard
                            </a>
                            <a href="@Url.Action("Appointments", "Doctor")" class="btn btn-outline" style="margin-right: 8px;">
                                <i class="fas fa-calendar-check"></i> Appointments
                            </a>
                            <a href="@Url.Action("PatientHistory", "Doctor")" class="btn btn-outline" style="margin-right: 8px;">
                                <i class="fas fa-notes-medical"></i> EMR
                            </a>
                            <a href="@Url.Action("MyReferrals", "Doctor")" class="btn btn-outline" style="margin-right: 8px;">
                                <i class="fas fa-share-alt"></i> Referrals
                                @if (ViewBag.PendingReferrals > 0)
                                {
                                    <span class="badge badge-danger">@ViewBag.PendingReferrals</span>
                                }
                            </a>


                        }
                        @if (User.IsInRole("Receptionist"))
                        {
                            <a href="@Url.Action("Dashboard", "Receptionist")" class="btn btn-outline" style="margin-right: 8px;">
                                <i class="fas fa-headset"></i> Dashboard
                            </a>
                            <a href="@Url.Action("AllAppointments", "Receptionist")" class="btn btn-outline" style="margin-right: 8px;">
                                <i class="fas fa-calendar-alt"></i> Schedule
                            </a>
                            <a href="@Url.Action("AllAppointments", "Receptionist")" class="btn btn-outline">
                                <i class="fas fa-calendar-alt"></i> Schedule
                            </a>


                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-outline" style="margin-right: 8px;">
                                <i class="fas fa-crown"></i> Admin
                            </a>
                            <a href="@Url.Action("Users", "Admin")" class="btn btn-outline" style="margin-right: 8px;">
                                <i class="fas fa-users-cog"></i> Users
                            </a>
                            <a href="@Url.Action("PendingDoctors", "Admin")" class="btn btn-outline" style="margin-right: 8px;">
                                <i class="fas fa-user-check"></i> Verify
                            </a>
                            <a href="@Url.Action("CreateUser", "Admin")" class="btn btn-outline" style="margin-right: 8px;">
                                <i class="fas fa-user-plus"></i> Add User
                            </a>
                            <a href="@Url.Action("Index", "Invoice")" class="btn btn-outline" style="margin-right: 8px;">
                                <i class="fas fa-file-invoice"></i> Invoices
                            </a>


                        }

                        <span class="navbar-text">
                            <i class="fas fa-user-circle"></i> @User.Identity.Name
                        </span>
                        <form asp-action="Logout" asp-controller="Account" method="post" style="display:inline;">
                            <button type="submit" class="btn btn-outline" style="background:transparent; border:1px solid #0056a7; color:#0056a7; padding:8px 20px; border-radius:25px; cursor:pointer;">Logout</button>
                        </form>
                    }
                    else
                    {
                        <a href="@Url.Action("Login", "Account")" class="btn btn-outline">Login</a>
                        <a href="@Url.Action("Register", "Account")" class="btn btn-primary">Register</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-col">
                    <h4>MediCloud Hospital</h4>
                    <p>Providing compassionate, high-quality healthcare to our community for over 20 years.</p>
                </div>
                <div class="footer-col">
                    <h4>Quick Links</h4>
                    <ul>
                        <li><a href="@Url.Action("Doctors", "Home")">Find a Doctor</a></li>
                        <li><a href="@Url.Action("Services", "Home")">Our Services</a></li>
                        <li><a href="@Url.Action("Packages", "Home")">Health Packages</a></li>
                        <li><a href="javascript:void(0);" onclick="showUpcomingToast('Careers')">Careers</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Contact</h4>
                    <p><i class="fas fa-phone"></i> 03-1234 5678</p>
                    <p><i class="fas fa-envelope"></i> info@medicloud.com</p>
                    <p><i class="fas fa-map-marker-alt"></i> 123, Jalan Medik, 47100 Puchong</p>
                </div>
                <div class="footer-col">
                    <h4>Follow Us</h4>
                    <div class="social-icons">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2025 MediCloud Hospital. All rights reserved.</p>
            </div>
        </div>
    </footer>

        <!-- jQuery (Required for validation) -->
        <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

        <script src="~/js/main.js"></script>
        @RenderSection("Styles", required: false)
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        @RenderSection("Scripts", required: false)
    </body>
    </html>