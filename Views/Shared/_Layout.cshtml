<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/style.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="container">
            <div class="nav-brand">
                <i class="fas fa-hospital-alt"></i>
                <span>MediCloud</span>
                <span class="hospital-badge">Hospital</span>
            </div>
            <ul class="nav-links">
                <li><a href="@Url.Action("Index")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">Home</a></li>
                <li><a href="@Url.Action("Doctors")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Doctors" ? "active" : "")">Find a Doctor</a></li>
                <li><a href="@Url.Action("Services")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Services" ? "active" : "")">Our Services</a></li>
                <li><a href="@Url.Action("Packages")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Packages" ? "active" : "")">Health Packages</a></li>
                <li><a href="@Url.Action("Contact")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Contact" ? "active" : "")">Contact Us</a></li>
            </ul>
            <div class="nav-buttons">
                @if (User.Identity.IsAuthenticated)
                {
                    <span class="navbar-text">
                        <i class="fas fa-user-circle"></i> @User.Identity.Name
                    </span>
                    <form asp-action="Logout" asp-controller="Account" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-outline" style="background:transparent; border:1px solid #0056a7; color:#0056a7; padding:8px 20px; border-radius:25px; cursor:pointer;">Logout</button>
                    </form>
                }
                else
                {
                    <a href="@Url.Action("Login", "Account")" class="btn btn-outline">Login</a>
                    <a href="@Url.Action("Register", "Account")" class="btn btn-primary">Register</a>
                }
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-col">
                    <h4>MediCloud Hospital</h4>
                    <p>Providing compassionate, high-quality healthcare to our community for over 20 years.</p>
                </div>
                <div class="footer-col">
                    <h4>Quick Links</h4>
                    <ul>
                        <li><a href="@Url.Action("Doctors")">Find a Doctor</a></li>
                        <li><a href="@Url.Action("Services")">Our Services</a></li>
                        <li><a href="@Url.Action("Packages")">Health Packages</a></li>
                        <li><a href="#">Careers</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Contact</h4>
                    <p><i class="fas fa-phone"></i> 03-1234 5678</p>
                    <p><i class="fas fa-envelope"></i> info@medicloud.com</p>
                    <p><i class="fas fa-map-marker-alt"></i> 123, Jalan Medik, 47100 Puchong</p>
                </div>
                <div class="footer-col">
                    <h4>Follow Us</h4>
                    <div class="social-icons">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2025 MediCloud Hospital. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="~/js/main.js"></script>
    @RenderSection("Styles", required: false)
</body>
</html>