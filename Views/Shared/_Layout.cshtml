<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap-grid.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap-utilities.min.css" />
    <link rel="stylesheet" href="~/css/style.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
</head>
<body>

    <!-- Navigation -->
    <nav class="navbar">
        <div class="container">
            <div class="nav-brand">
                <i class="fas fa-hospital-alt"></i>
                <span>MediCloud</span>
                <span class="hospital-badge">Hospital</span>
            </div>
            
            <button class="navbar-toggler" type="button" onclick="toggleMobileMenu()">
                <i class="fas fa-bars"></i>
            </button>
            
            <div class="navbar-collapse" id="navbarCollapse">
                <ul class="nav-links">
                    <li><a href="@Url.Action("Index", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">Home</a></li>
                    <li><a href="@Url.Action("Doctors", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Doctors" ? "active" : "")">Find a Doctor</a></li>
                    <li><a href="@Url.Action("Services", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Services" ? "active" : "")">Our Services</a></li>
                    <li><a href="@Url.Action("Packages", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Packages" ? "active" : "")">Health Packages</a></li>
                    <li><a href="@Url.Action("Contact", "Home")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Contact" ? "active" : "")">Contact Us</a></li>
                </ul>
                <div class="nav-right">
                    <div class="nav-buttons">
                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Patient"))
                            {
                                <a href="@Url.Action("Dashboard", "Patient")" class="btn btn-primary">
                                    <i class="fas fa-user-md"></i> Dashboard
                                </a>
                            }
                            @if (User.IsInRole("Doctor"))
                            {
                                <a href="@Url.Action("Dashboard", "Doctor")" class="btn btn-primary">
                                    <i class="fas fa-stethoscope"></i> Dashboard
                                </a>
                            }
                            @if (User.IsInRole("Receptionist"))
                            {
                                <a href="@Url.Action("Dashboard", "Receptionist")" class="btn btn-primary">
                                    <i class="fas fa-headset"></i> Dashboard
                                </a>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-primary">
                                    <i class="fas fa-crown"></i> Admin
                                </a>
                            }

                            <!-- User Dropdown Menu -->
                            <div class="user-dropdown">
                                <button class="dropdown-toggle" type="button" onclick="toggleUserDropdown(event)">
                                    <i class="fas fa-user-circle"></i> @User.Identity.Name <i class="fas fa-chevron-down" style="font-size: 0.7rem; margin-left: 4px;"></i>
                                </button>
                                <div class="dropdown-menu" id="userDropdownMenu">
                                    @if (User.IsInRole("Patient"))
                                    {
                                        <a href="@Url.Action("MyInvoices", "Invoice")">
                                            <i class="fas fa-file-invoice"></i> My Invoices
                                        </a>
                                    }
                                    @if (User.IsInRole("Doctor"))
                                    {
                                        <a href="@Url.Action("PatientHistory", "Doctor")">
                                            <i class="fas fa-notes-medical"></i> EMR
                                        </a>
                                        <a href="@Url.Action("MyReferrals", "Doctor")">
                                            <i class="fas fa-share-alt"></i> Referrals
                                            @if (ViewBag.PendingReferrals > 0)
                                            {
                                                <span class="badge badge-danger">@ViewBag.PendingReferrals</span>
                                            }
                                        </a>
                                    }
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a href="@Url.Action("Users", "Admin")">
                                            <i class="fas fa-users-cog"></i> Users
                                        </a>
                                        <a href="@Url.Action("PendingDoctors", "Admin")">
                                            <i class="fas fa-user-check"></i> Verify Doctors
                                        </a>
                                        <a href="@Url.Action("CreateUser", "Admin")">
                                            <i class="fas fa-user-plus"></i> Add User
                                        </a>
                                        <a href="@Url.Action("Index", "Invoice")">
                                            <i class="fas fa-file-invoice"></i> Invoices
                                        </a>
                                    }
                                    <div class="dropdown-divider"></div>
                                    <form asp-action="Logout" asp-controller="Account" method="post" style="display:block; margin:0;">
                                        <button type="submit" class="dropdown-item-logout">
                                            <i class="fas fa-sign-out-alt"></i> Logout
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                        else
                        {
                            <a href="@Url.Action("Login", "Account")" class="btn btn-outline">Login</a>
                            <a href="@Url.Action("Register", "Account")" class="btn btn-primary">Register</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </nav>

    

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-col">
                    <h4>MediCloud Hospital</h4>
                    <p>Providing compassionate, high-quality healthcare to our community for over 20 years.</p>
                </div>
                <div class="footer-col">
                    <h4>Quick Links</h4>
                    <ul>
                        <li><a href="@Url.Action("Doctors", "Home")">Find a Doctor</a></li>
                        <li><a href="@Url.Action("Services", "Home")">Our Services</a></li>
                        <li><a href="@Url.Action("Packages", "Home")">Health Packages</a></li>
                        <li><a href="javascript:void(0);" onclick="showUpcomingToast('Careers')">Careers</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Contact</h4>
                    <p><i class="fas fa-phone"></i> 03-1234 5678</p>
                    <p><i class="fas fa-envelope"></i> info@medicloud.com</p>
                    <p><i class="fas fa-map-marker-alt"></i> 123, Jalan Medik, 47100 Puchong</p>
                </div>
                <div class="footer-col">
                    <h4>Follow Us</h4>
                    <div class="social-icons">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2025 MediCloud Hospital. All rights reserved.</p>
            </div>
        </div>
    </footer>

        <!-- jQuery (Required for validation) -->
        <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

        <script src="~/js/main.js"></script>
        @RenderSection("Styles", required: false)
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        @RenderSection("Scripts", required: false)

        <!-- Global Custom Confirm Modal -->
        <div id="globalConfirmModal" class="modal" style="display:none; position:fixed; z-index:10005; left:0; top:0; width:100%; height:100%; background-color: rgba(0,0,0,0.5); align-items:center; justify-content:center;">
            <div class="modal-content" style="background-color:#fff; padding:30px; border-radius:12px; max-width:400px; width:90%; position:relative; box-shadow: 0 5px 25px rgba(0,0,0,0.2); text-align:center; animation: zoomIn 0.3s;">
                <span class="global-close-modal" style="position:absolute; right:20px; top:15px; font-size:1.8rem; color:#aaa; cursor:pointer;">&times;</span>
                <h3 id="globalConfirmTitle" style="color:#dc3545; margin-bottom:15px;"><i class="fas fa-exclamation-triangle"></i> Confirm Action</h3>
                <p id="globalConfirmMessage" style="margin-bottom:25px; color:#555; font-size:0.95rem; line-height: 1.5;"></p>
                <div style="display:flex; gap:15px; justify-content:center; flex-wrap:wrap;">
                    <button id="globalConfirmYesBtn" type="button" class="btn btn-danger" style="padding:10px 24px; border-radius:20px; font-weight:600; cursor:pointer;">Yes, Proceed</button>
                    <button id="globalConfirmCancelBtn" type="button" class="btn btn-outline" style="padding:10px 24px; border-radius:20px; font-weight:600; border:1px solid #ddd; color:#555; background:transparent; cursor:pointer;">Cancel</button>
                </div>
            </div>
        </div>
    </body>
</html>