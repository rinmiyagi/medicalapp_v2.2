@model medicalapp.Models.ViewModels.AdminCreateUserViewModel

@{
    ViewData["Title"] = "Create User - MediCloud";
    Layout = "_Layout";
}

<div class="create-user-container">
    <div class="container">
        <h2>👤 Create New User</h2>
        <p class="text-muted">Add a new doctor, receptionist, or admin to the system.</p>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <div class="create-card">
            <form asp-action="CreateUser" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- Personal Information -->
                <div class="form-section">
                    <h4>Personal Information</h4>
                    <div class="form-row">
                        <div class="form-group half">
                            <label asp-for="FirstName"></label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="form-group half">
                            <label asp-for="LastName"></label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group half">
                            <label asp-for="Email"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="form-group half">
                            <label asp-for="ICNumber"></label>
                            <input asp-for="ICNumber" class="form-control" placeholder="000101-10-1234" />
                            <span asp-validation-for="ICNumber" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group half">
                            <label asp-for="Gender"></label>
                            <select asp-for="Gender" class="form-control">
                                <option value="">Select</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                            </select>
                            <span asp-validation-for="Gender" class="text-danger"></span>
                        </div>
                        <div class="form-group half">
                            <label asp-for="DateOfBirth"></label>
                            <input asp-for="DateOfBirth" class="form-control" type="date" />
                            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Role & Credentials -->
                <div class="form-section">
                    <h4>Role & Credentials</h4>
                    <div class="form-group">
                        <label asp-for="Role"></label>
                        <select asp-for="Role" class="form-control" id="roleSelect" onchange="toggleDoctorFields()">
                            <option value="">Select Role</option>
                            <option value="Doctor">Doctor</option>
                            <option value="Receptionist">Receptionist</option>
                            <option value="Admin">Admin</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger"></span>
                    </div>

                    <div class="form-row">
                        <div class="form-group half">
                            <label asp-for="Password"></label>
                            <input asp-for="Password" class="form-control" type="password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <div class="form-group half">
                            <label asp-for="ConfirmPassword"></label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Doctor Specific Fields -->
                <div class="form-section doctor-fields" id="doctorFields" style="display:none;">
                    <h4>Doctor Details</h4>
                    <div class="form-row">
                        <div class="form-group half">
                            <label asp-for="Specialization"></label>
                            <input asp-for="Specialization" class="form-control" placeholder="e.g., Cardiology" />
                        </div>
                        <div class="form-group half">
                            <label asp-for="Department"></label>
                            <input asp-for="Department" class="form-control" placeholder="e.g., Cardiology Department" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group half">
                            <label asp-for="LicenseNumber"></label>
                            <input asp-for="LicenseNumber" class="form-control" placeholder="e.g., MED-2025-001" />
                        </div>
                        <div class="form-group half">
                            <label asp-for="YearsOfExperience"></label>
                            <input asp-for="YearsOfExperience" class="form-control" type="number" min="0" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="ConsultationFee"></label>
                        <input asp-for="ConsultationFee" class="form-control" type="number" step="5" min="0" placeholder="e.g., 150.00" />
                    </div>

                    <div class="form-group">
                        <label asp-for="Bio"></label>
                        <textarea asp-for="Bio" class="form-control" rows="3" placeholder="Brief bio about the doctor..."></textarea>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-user-plus"></i> Create User
                    </button>
                    <a href="@Url.Action("Users")" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleDoctorFields() {
            var role = document.getElementById('roleSelect').value;
            var doctorFields = document.getElementById('doctorFields');
            if (role === 'Doctor') {
                doctorFields.style.display = 'block';
            } else {
                doctorFields.style.display = 'none';
            }
        }

        // Call on page load to show/hide based on current selection
        document.addEventListener('DOMContentLoaded', function() {
            toggleDoctorFields();
        });
    </script>
}

@section Styles {
    <style>
        .create-user-container { padding: 40px 0; }
        .create-user-container h2 { color: #003366; margin-bottom: 5px; }
        .text-muted { color: #666; }

        .create-card {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            max-width: 700px;
            margin-top: 25px;
        }

        .form-section {
            margin-bottom: 25px;
            padding-bottom: 20px;
            border-bottom: 1px solid #eee;
        }

        .form-section:last-child { border-bottom: none; }

        .form-section h4 {
            color: #003366;
            margin-bottom: 15px;
            font-size: 1rem;
        }

        .form-row { display: flex; gap: 15px; }
        .form-row .half { flex: 1; }

        .form-group { margin-bottom: 15px; }

        .form-control {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
        }

        .form-control:focus { outline: none; border-color: #0056a7; }

        .form-actions {
            margin-top: 20px;
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .btn {
            padding: 10px 24px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            cursor: pointer;
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary { background: #0056a7; color: white; }
        .btn-primary:hover { background: #003d7a; }
        .btn-outline { background: transparent; color: #0056a7; border: 1px solid #0056a7; }
        .btn-outline:hover { background: #0056a7; color: white; }

        .text-danger { color: #dc3545; font-size: 0.9rem; }

        .alert {
            padding: 12px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
        .alert-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }

        @@media (max-width: 768px) {
            .form-row { flex-direction: column; }
            .form-row .half { width: 100%; }
        }
    </style>
}