@{
    ViewData["Title"] = "Reset Password Confirmation - MediCloud";
    Layout = "_Layout";
}

<section class="auth-section">
    <div class="container">
        <div class="auth-box text-center">
            <i class="fas fa-check-circle text-success mb-3" style="font-size: 3.5rem;"></i>
            <h2>Password Reset Complete</h2>
            <p>Your password has been successfully updated. You can now log in using your new credentials.</p>

            <a href="@Url.Action("Login")" class="btn btn-primary btn-block mt-3">Go to Login</a>
        </div>
    </div>
</section>

@section Styles {
    <style>
        .auth-section {
            padding: 60px 0;
            background: #f4f6f9;
            min-height: 70vh;
        }
        .auth-box {
            max-width: 400px;
            margin: 0 auto;
            background: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        }
        .auth-box h2 {
            margin-bottom: 10px;
            color: #003366;
        }
        .auth-box p {
            color: #666;
            margin-bottom: 20px;
            font-size: 15px;
            line-height: 1.5;
        }
        .btn-block {
            width: 100%;
            padding: 12px;
        }
    </style>
}
