@{
    ViewData["Title"] = "Confirm Email - MediCloud";
    Layout = "_Layout";
}

<section class="auth-section">
    <div class="container">
        <div class="auth-box">
            <div class="email-icon-container">
                <i class="fas fa-envelope-open-text"></i>
            </div>
            <h2>Confirm Your Email</h2>
            <p class="desc-text">
                We have sent a verification email to <strong style="color: #003366;">@ViewBag.Email</strong>.<br />
                Please check your inbox and click the verification link to activate your account.
            </p>

            <!-- Debug Sandbox for Local Testing -->
            <div class="sandbox-card">
                <h4><i class="fas fa-bug"></i> Developer Sandbox</h4>
                <p>
                    Since this is a local development environment, no actual email was sent. Please click the button below to simulate confirmation.
                </p>
                <a href="@Url.Action("ConfirmEmail", "Account", new { userId = ViewBag.UserId, token = ViewBag.Token })" class="btn btn-primary btn-block custom-btn">
                    <i class="fas fa-envelope-open"></i> Simulate Confirming Email
                </a>
            </div>

            <div class="auth-links">
                <a href="@Url.Action("Login", "Account")" class="btn btn-outline btn-block custom-btn" style="text-decoration: none;">Back to Login</a>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        .auth-section {
            padding: 60px 0;
            background: #f4f6f9;
            min-height: 70vh;
            display: flex;
            align-items: center;
        }
        .auth-box {
            max-width: 500px;
            margin: 0 auto;
            background: white;
            padding: 45px 40px;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.06);
            text-align: center;
            animation: zoomIn 0.3s ease-out;
        }
        .email-icon-container {
            font-size: 4rem;
            color: #0056a7;
            margin-bottom: 20px;
            animation: bounce 2s infinite;
            display: inline-block;
        }
        .auth-box h2 {
            margin-bottom: 10px;
            color: #003366;
            font-size: 1.8rem;
        }
        .desc-text {
            color: #555;
            margin-bottom: 25px;
            font-size: 0.95rem;
            line-height: 1.6;
        }
        .sandbox-card {
            background: #eef5fc;
            padding: 20px;
            border-radius: 12px;
            border: 1px solid rgba(0,86,167,0.15);
            margin-bottom: 25px;
            text-align: left;
        }
        .sandbox-card h4 {
            color: #0056a7;
            margin-top: 0;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 1.05rem;
        }
        .sandbox-card p {
            font-size: 0.85rem;
            color: #555;
            margin-bottom: 15px;
            line-height: 1.4;
        }
        .btn-block {
            width: 100%;
            padding: 12px;
            border-radius: 25px;
            font-weight: 600;
        }
        .custom-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .btn-primary {
            background: #0056a7;
            color: white;
            border: none;
            cursor: pointer;
            transition: background-color 0.2s;
        }
        .btn-primary:hover {
            background: #003d7a;
        }
        .btn-outline {
            background: transparent;
            color: #555;
            border: 1px solid #ddd;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn-outline:hover {
            background: #f8f9fa;
            border-color: #ccc;
        }

        @@keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
    </style>
}
