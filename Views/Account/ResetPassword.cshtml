@model medicalapp.Models.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password - MediCloud";
    Layout = "_Layout";
}

<section class="auth-section">
    <div class="container">
        <div class="auth-box">
            <h2>Reset Password</h2>
            <p>Set a new password for your account.</p>

            <form asp-action="ResetPassword" method="post">
                <div asp-validation-summary="All" class="text-danger"></div>
                
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Token" />

                <div class="form-group">
                    <label asp-for="Password">New Password</label>
                    <div class="password-container">
                        <input asp-for="Password" id="password-field" class="form-control" type="password" placeholder="Min 6 characters" />
                        <i class="fas fa-eye toggle-password" onclick="togglePasswordVisibility('password-field', this)"></i>
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword">Confirm New Password</label>
                    <div class="password-container">
                        <input asp-for="ConfirmPassword" id="confirm-password-field" class="form-control" type="password" placeholder="Repeat your new password" />
                        <i class="fas fa-eye toggle-password" onclick="togglePasswordVisibility('confirm-password-field', this)"></i>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-block">Reset Password</button>
            </form>
        </div>
    </div>
</section>

@section Styles {
    <style>
        .auth-section {
            padding: 60px 0;
            background: #f4f6f9;
            min-height: 70vh;
        }
        .auth-box {
            max-width: 400px;
            margin: 0 auto;
            background: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        }
        .auth-box h2 {
            margin-bottom: 5px;
            color: #003366;
        }
        .auth-box p {
            color: #666;
            margin-bottom: 20px;
            font-size: 14px;
        }
        .form-group {
            margin-bottom: 20px;
        }
        .form-control {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
        }
        .form-control:focus {
            outline: none;
            border-color: #0056a7;
        }
        .btn-block {
            width: 100%;
            padding: 12px;
            margin-top: 10px;
        }
        .text-danger {
            color: #dc3545;
            font-size: 13px;
        }
        .password-container {
            position: relative;
            display: flex;
            align-items: center;
        }
        .toggle-password {
            position: absolute;
            right: 12px;
            cursor: pointer;
            color: #aaa;
        }
        .toggle-password:hover {
            color: #666;
        }
    </style>
}
