@{
    ViewData["Title"] = "Forgot Password Confirmation - MediCloud";
    Layout = "_Layout";
}

<section class="auth-section">
    <div class="container">
        <div class="auth-box text-center">
            <i class="fas fa-envelope-open-text text-primary mb-3" style="font-size: 3.5rem;"></i>
            <h2>Check Your Email</h2>
            <p>If the email <strong>@ViewBag.Email</strong> exists in our system, we have sent a password reset link.</p>

            <!-- Local Development Mock Link -->
            @if (!string.IsNullOrEmpty(ViewBag.Token))
            {
                <div class="alert alert-info mt-4 text-start">
                    <h5 class="fw-bold mb-2"><i class="fas fa-tools"></i> Local Development Mock</h5>
                    <p class="mb-3 small">SMTP server is not configured in this local workspace. Use the mock button below to proceed to the password reset page.</p>
                    <a href="@Url.Action("ResetPassword", "Account", new { token = ViewBag.Token, email = ViewBag.Email })" class="btn btn-warning btn-block">
                        <i class="fas fa-key"></i> Click here to reset your password
                    </a>
                </div>
            }

            <div class="auth-links mt-4">
                <p><a href="@Url.Action("Login")">Back to Login</a></p>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        .auth-section {
            padding: 60px 0;
            background: #f4f6f9;
            min-height: 70vh;
        }
        .auth-box {
            max-width: 450px;
            margin: 0 auto;
            background: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        }
        .auth-box h2 {
            margin-bottom: 10px;
            color: #003366;
        }
        .auth-box p {
            color: #666;
            margin-bottom: 20px;
            font-size: 15px;
            line-height: 1.5;
        }
        .btn-block {
            width: 100%;
            padding: 12px;
            margin-top: 10px;
        }
        .auth-links {
            text-align: center;
        }
        .auth-links a {
            color: #0056a7;
            text-decoration: none;
            font-size: 14px;
        }
        .alert-info {
            background-color: #eef5fc;
            border: 1px solid #b8daff;
            color: #004085;
            border-radius: 8px;
            padding: 20px;
        }
        .btn-warning {
            background-color: #ffc107;
            border-color: #ffc107;
            color: #212529;
            font-weight: 600;
        }
        .btn-warning:hover {
            background-color: #e0a800;
            border-color: #d39e00;
        }
    </style>
}
