@{
    ViewData["Title"] = "Email Confirmation - MediCloud";
    Layout = "_Layout";
    var status = ViewBag.Status as string;
    var message = ViewBag.Message as string;
}

<section class="auth-section">
    <div class="container">
        <div class="auth-box">
            @if (status == "Success")
            {
                <div class="status-icon-container success-icon">
                    <i class="fas fa-check-circle"></i>
                </div>
                <h2>Email Confirmed!</h2>
                <p class="desc-text">@message</p>
                <a href="@Url.Action("Login", "Account")" class="btn btn-primary btn-block" style="text-decoration: none;">Go to Login</a>
            }
            else
            {
                <div class="status-icon-container error-icon">
                    <i class="fas fa-times-circle"></i>
                </div>
                <h2>Confirmation Failed</h2>
                <p class="desc-text">@message</p>
                <a href="@Url.Action("Register", "Account")" class="btn btn-outline btn-block" style="text-decoration: none;">Back to Register</a>
            }
        </div>
    </div>
</section>

@section Styles {
    <style>
        .auth-section {
            padding: 60px 0;
            background: #f4f6f9;
            min-height: 70vh;
            display: flex;
            align-items: center;
        }
        .auth-box {
            max-width: 450px;
            margin: 0 auto;
            background: white;
            padding: 45px 40px;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.06);
            text-align: center;
            animation: zoomIn 0.3s ease-out;
        }
        .status-icon-container {
            font-size: 4.5rem;
            margin-bottom: 20px;
            display: inline-block;
        }
        .success-icon {
            color: #28a745;
        }
        .error-icon {
            color: #dc3545;
        }
        .auth-box h2 {
            margin-bottom: 15px;
            color: #003366;
            font-size: 1.8rem;
        }
        .desc-text {
            color: #555;
            margin-bottom: 30px;
            font-size: 0.95rem;
            line-height: 1.6;
        }
        .btn-block {
            width: 100%;
            padding: 12px;
            border-radius: 25px;
            font-weight: 600;
        }
        .btn-primary {
            background: #0056a7;
            color: white;
            border: none;
            cursor: pointer;
            transition: background-color 0.2s;
        }
        .btn-primary:hover {
            background: #003d7a;
        }
        .btn-outline {
            background: transparent;
            color: #555;
            border: 1px solid #ddd;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn-outline:hover {
            background: #f8f9fa;
            border-color: #ccc;
        }
    </style>
}
