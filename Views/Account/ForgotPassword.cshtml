@model medicalapp.Models.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password - MediCloud";
    Layout = "_Layout";
}

<section class="auth-section">
    <div class="container">
        <div class="auth-box">
            <h2>Forgot Password</h2>
            <p>Enter your email address to receive a password reset link.</p>

            <form asp-action="ForgotPassword" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-control" placeholder="Enter your registered email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-block">Send Reset Link</button>
            </form>

            <div class="auth-links">
                <p><a href="@Url.Action("Login")"><i class="fas fa-arrow-left"></i> Back to Login</a></p>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        .auth-section {
            padding: 60px 0;
            background: #f4f6f9;
            min-height: 70vh;
        }
        .auth-box {
            max-width: 400px;
            margin: 0 auto;
            background: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        }
        .auth-box h2 {
            margin-bottom: 5px;
            color: #003366;
        }
        .auth-box p {
            color: #666;
            margin-bottom: 20px;
            font-size: 14px;
        }
        .form-group {
            margin-bottom: 20px;
        }
        .form-control {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
        }
        .form-control:focus {
            outline: none;
            border-color: #0056a7;
        }
        .btn-block {
            width: 100%;
            padding: 12px;
            margin-top: 10px;
        }
        .auth-links {
            text-align: center;
            margin-top: 20px;
        }
        .auth-links a {
            color: #0056a7;
            text-decoration: none;
            font-size: 14px;
        }
        .text-danger {
            color: #dc3545;
            font-size: 13px;
        }
    </style>
}
