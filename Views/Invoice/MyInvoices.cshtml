@model List<medicalapp.Models.Invoice>

@{
    ViewData["Title"] = "My Invoices - MediCloud";
    Layout = "_Layout";
}

<div class="invoices-container">
    <div class="container">
        <h2>🧾 My Invoices</h2>
        <p class="text-muted">View your consultation invoices.</p>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        @if (Model.Any())
        {
            <div class="invoice-list">
                <div class="invoice-header-row">
                    <span>Invoice #</span>
                    <span>Doctor</span>
                    <span>Date</span>
                    <span>Total</span>
                    <span>Status</span>
                    <span>Actions</span>
                </div>
                @foreach (var invoice in Model)
                {
                    <div class="invoice-item">
                        <span>@invoice.InvoiceNumber</span>
                        <span>Dr. @invoice.Appointment?.Doctor?.User?.FirstName @invoice.Appointment?.Doctor?.User?.LastName</span>
                        <span>@invoice.IssueDate.ToString("dd MMM yyyy")</span>
                        <span>RM @invoice.TotalAmount.ToString("F2")</span>
                        <span class="status-badge @(invoice.Status == "Paid" ? "paid" : "unpaid")">@invoice.Status</span>
                        <span>
                            <a href="@Url.Action("Details", new { id = invoice.Id })" class="btn btn-sm btn-outline">View</a>
                        </span>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="empty-state">No invoices found.</p>
        }
    </div>
</div>

@section Styles {
    <style>
        .invoices-container { padding: 40px 0; }
        .invoices-container h2 { color: #003366; margin-bottom: 5px; }

        .invoice-header-row {
            display: grid;
            grid-template-columns: 1fr 1.5fr 1fr 1fr 1fr 1fr;
            padding: 12px 16px;
            background: #f4f6f9;
            font-weight: 600;
            color: #003366;
            border-radius: 8px;
            margin-bottom: 8px;
        }

        .invoice-item {
            display: grid;
            grid-template-columns: 1fr 1.5fr 1fr 1fr 1fr 1fr;
            padding: 12px 16px;
            background: white;
            border-radius: 8px;
            margin-bottom: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
            align-items: center;
        }

        .status-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            text-align: center;
        }

        .status-badge.paid { background: #28a745; color: white; }
        .status-badge.unpaid { background: #ffc107; color: #856404; }

        .btn-sm { padding: 4px 12px; font-size: 0.85rem; }
        .btn-outline { background: transparent; color: #0056a7; border: 1px solid #0056a7; border-radius: 6px; text-decoration: none; padding: 5px 12px; }
        .btn-outline:hover { background: #0056a7; color: white; }

        .empty-state { text-align: center; padding: 40px; background: #f8f9fa; border-radius: 8px; color: #666; }

        .alert { padding: 12px 20px; border-radius: 8px; margin-bottom: 20px; }
        .alert-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }

        .text-muted { color: #666; }
    </style>
}