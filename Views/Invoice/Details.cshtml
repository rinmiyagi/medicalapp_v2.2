@model medicalapp.Models.Invoice

@{
    ViewData["Title"] = "Invoice - MediCloud";
    Layout = "_Layout";
}

<div class="invoice-container">
    <div class="container">
        <div class="invoice-header">
            <h2>🧾 INVOICE</h2>
            <p class="invoice-number">#@Model.InvoiceNumber</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <div class="invoice-details">
            <div class="row">
                <div class="col">
                    <p><strong>Patient:</strong> @Model.Patient?.User?.FirstName @Model.Patient?.User?.LastName</p>
                    <p><strong>Date:</strong> @Model.IssueDate.ToString("dd MMM yyyy")</p>
                    <p><strong>Status:</strong> 
                        <span class="badge @(Model.Status == "Paid" ? "bg-success" : "bg-warning")">
                            @Model.Status
                        </span>
                    </p>
                </div>
                <div class="col">
                    <p><strong>Doctor:</strong> Dr. @Model.Appointment?.Doctor?.User?.FirstName @Model.Appointment?.Doctor?.User?.LastName</p>
                    <p><strong>Due Date:</strong> @Model.DueDate?.ToString("dd MMM yyyy")</p>
                    @if (Model.IsSyncedWithLhdn)
                    {
                        <p><strong>LHDN Ref:</strong> @Model.LhdnReferenceId</p>
                    }
                </div>
            </div>
        </div>

        <div class="invoice-table">
            <table class="table">
                <thead>
                    <tr>
                        <th>Description</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>
                            @if (Model.Appointment?.ReasonForVisit != null && Model.Appointment.ReasonForVisit.StartsWith("Health Screening:"))
                            {
                                @Model.Appointment.ReasonForVisit
                            }
                            else
                            {
                                <text>Consultation - Dr. @Model.Appointment?.Doctor?.User?.FirstName @Model.Appointment?.Doctor?.User?.LastName</text>
                            }
                        </td>
                        <td>RM @Model.SubTotal.ToString("F2")</td>
                    </tr>
                    <tr>
                        <td>SST (6%)</td>
                        <td>RM @Model.TaxAmount.ToString("F2")</td>
                    </tr>
                    <tr class="total-row">
                        <td><strong>Total</strong></td>
                        <td><strong>RM @Model.TotalAmount.ToString("F2")</strong></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="invoice-actions">
            @if (User.IsInRole("Admin") || User.IsInRole("Receptionist"))
            {
                @if (Model.Status == "Unpaid")
                {
                    <form asp-action="MarkAsPaid" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <select name="paymentMethod" class="form-control" style="display:inline-block; width:auto;">
                            <option value="Cash">Cash</option>
                            <option value="Credit Card">Credit Card</option>
                            <option value="Online Banking">Online Banking</option>
                        </select>
                        <button type="submit" class="btn btn-success">Mark as Paid</button>
                    </form>
                }
                @if (Model.Status == "Paid" && !Model.IsSyncedWithLhdn)
                {
                    <form asp-action="SyncWithLhdn" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-info">Sync with LHDN</button>
                    </form>
                }
            }
            <a href="@Url.Action("Index", "Invoice")" class="btn btn-outline">Back to Invoices</a>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .invoice-container { padding: 40px 0; }
        .invoice-header { border-bottom: 2px solid #003366; padding-bottom: 10px; margin-bottom: 20px; }
        .invoice-header h2 { color: #003366; }
        .invoice-number { color: #666; font-size: 1.2rem; }
        .invoice-details { background: #f8f9fa; padding: 20px; border-radius: 8px; margin-bottom: 20px; }
        .total-row { border-top: 2px solid #003366; font-size: 1.2rem; }
        .invoice-actions { margin-top: 20px; display: flex; gap: 10px; flex-wrap: wrap; }
        .badge { padding: 5px 15px; border-radius: 20px; font-size: 0.9rem; }
        .bg-success { background: #28a745; color: white; }
        .bg-warning { background: #ffc107; color: #856404; }
        .table { width: 100%; border-collapse: collapse; }
        .table th, .table td { padding: 12px; text-align: left; border-bottom: 1px solid #ddd; }
        .form-control { padding: 8px 12px; border: 1px solid #ddd; border-radius: 8px; }
        .btn { padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: 600; border: none; cursor: pointer; }
        .btn-success { background: #28a745; color: white; }
        .btn-info { background: #17a2b8; color: white; }
        .btn-outline { background: transparent; color: #0056a7; border: 1px solid #0056a7; }
        .alert { padding: 12px 20px; border-radius: 8px; margin-bottom: 20px; }
        .alert-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .row { display: flex; gap: 20px; flex-wrap: wrap; }
        .col { flex: 1; min-width: 200px; }
    </style>
}