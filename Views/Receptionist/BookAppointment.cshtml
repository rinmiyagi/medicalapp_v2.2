@model medicalapp.Models.ViewModels.ReceptionistBookAppointmentViewModel

@{
    ViewData["Title"] = "Book Appointment - MediCloud";
    Layout = "_Layout";
}

<div class="booking-container">
    <div class="container">
        <h2>📅 Book Appointment (Receptionist)</h2>
        <p class="text-muted">Schedule an appointment for a patient.</p>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <div class="booking-card">
            <form asp-action="BookAppointment" method="post">
                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="form-group">
                    <label asp-for="PatientId"></label>
                    <select asp-for="PatientId" asp-items="Model.Patients" class="form-control">
                        <option value="">-- Select Patient --</option>
                    </select>
                    <span asp-validation-for="PatientId" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="DoctorId"></label>
                    <select asp-for="DoctorId" asp-items="Model.Doctors" class="form-control" id="DoctorId">
                        <option value="">-- Select Doctor --</option>
                    </select>
                    <span asp-validation-for="DoctorId" class="text-danger"></span>
                    <div id="availableDaysContainer" class="alert alert-info mt-2 py-2 px-3" style="display: none; font-size: 0.85rem; background: #eef5fc; border-color: #d0e3f5; color: #0056a7; border-radius: 8px;">
                        <i class="fas fa-calendar-alt me-1"></i> Available days for this doctor: 
                        <strong id="availableDaysList"></strong>
                    </div>
                </div>

                <div class="form-group">
                    <label>Appointment Date</label>
                    <input id="AppointmentDatePicker" class="form-control" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <small class="form-text text-muted">Please select preferred date first.</small>
                </div>

                <div class="form-group mt-3" id="slotSection" style="display: none;">
                    <label class="fw-bold d-block mb-2">Available Time Slots</label>
                    <div id="slotsContainer" class="d-flex flex-wrap gap-2">
                        <!-- Dynamic Slots Buttons -->
                    </div>
                    <input type="hidden" asp-for="AppointmentDate" id="AppointmentDateHidden" />
                    <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ReasonForVisit"></label>
                    <input asp-for="ReasonForVisit" class="form-control" placeholder="E.g., Chest pain, follow-up" />
                    <span asp-validation-for="ReasonForVisit" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Symptoms"></label>
                    <textarea asp-for="Symptoms" class="form-control" rows="3" placeholder="Describe symptoms (optional)"></textarea>
                    <span asp-validation-for="Symptoms" class="text-danger"></span>
                </div>

                <!-- Summary -->
                <div class="form-step summary mt-4" id="feeSummarySection" style="display: none; border-top: 1px solid #eee; padding-top: 20px; margin-bottom: 20px;">
                    <h4 style="color: #003366; font-size: 1rem; margin-bottom: 15px;">Appointment Summary</h4>
                    <div class="summary-grid" style="display: flex; flex-direction: column; gap: 10px;">
                        <div class="summary-item" style="display: flex; justify-content: space-between; font-size: 0.95rem;">
                            <span class="summary-label" style="color: #666;">Consultation Fee:</span>
                            <span class="summary-value" style="font-weight: 600; color: #333;">RM <span id="feeDisplay">0.00</span></span>
                        </div>
                        <div class="summary-item" style="display: flex; justify-content: space-between; font-size: 0.95rem;">
                            <span class="summary-label" style="color: #666;">Tax (6%):</span>
                            <span class="summary-value" style="font-weight: 600; color: #333;">RM <span id="taxDisplay">0.00</span></span>
                        </div>
                        <div class="summary-item total" style="display: flex; justify-content: space-between; font-size: 1.1rem; border-top: 2px solid #0056a7; padding-top: 10px; margin-top: 5px;">
                            <span class="summary-label" style="font-weight: 700; color: #003366;">Total Amount:</span>
                            <span class="summary-value" style="font-weight: 800; color: #003366;">RM <span id="totalDisplay">0.00</span></span>
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Confirm Booking</button>
                    <a href="@Url.Action("Dashboard")" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .booking-container { padding: 40px 0; }
        .booking-container h2 { color: #003366; margin-bottom: 5px; }
        .text-muted { color: #666; }

        .booking-card {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            max-width: 600px;
            margin-top: 25px;
        }

        .form-group { margin-bottom: 15px; }
        .form-control {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
        }
        .form-control:focus { outline: none; border-color: #0056a7; }

        .form-actions {
            margin-top: 20px;
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .btn {
            padding: 10px 24px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            cursor: pointer;
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary { background: #0056a7; color: white; }
        .btn-primary:hover { background: #003d7a; }
        .btn-outline { background: transparent; color: #0056a7; border: 1px solid #0056a7; }
        .btn-outline:hover { background: #0056a7; color: white; }

        .alert {
            padding: 12px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
        .alert-danger { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
        .text-danger { color: #dc3545; font-size: 0.9rem; }

        .slot-btn {
            border: 1px solid #dee2e6;
            background-color: #fff;
            color: #495057;
            padding: 10px 16px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.2s ease;
            cursor: pointer;
        }
        .slot-btn:hover:not(:disabled) {
            border-color: #0056a7;
            color: #0056a7;
            background-color: #eef5fc;
        }
        .slot-btn.active {
            background-color: #0056a7 !important;
            border-color: #0056a7 !important;
            color: #fff !important;
        }
        .slot-btn:disabled {
            background-color: #e9ecef;
            border-color: #dee2e6;
            color: #adb5bd;
            cursor: not-allowed;
        }
        .gap-2 { gap: 0.5rem; }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const doctorSelect = document.getElementById("DoctorId");
            const datePicker = document.getElementById("AppointmentDatePicker");
            const slotSection = document.getElementById("slotSection");
            const slotsContainer = document.getElementById("slotsContainer");
            const hiddenDateInput = document.getElementById("AppointmentDateHidden");
            let selectedTime = null;
            let availableDays = [];

            // Fetch Doctor Schedule & Price
            async function fetchDoctorSchedule() {
                const doctorId = doctorSelect.value;
                if (!doctorId) {
                    document.getElementById("availableDaysContainer").style.display = "none";
                    document.getElementById("feeSummarySection").style.display = "none";
                    availableDays = [];
                    resetSlots();
                    return;
                }

                try {
                    const response = await fetch(`/Patient/GetDoctorSchedule?doctorId=${doctorId}`);
                    if (response.ok) {
                        const data = await response.json();
                        
                        // Show available days
                        availableDays = data.availableDays || [];
                        if (availableDays.length > 0) {
                            document.getElementById("availableDaysList").textContent = availableDays.join(", ");
                            document.getElementById("availableDaysContainer").style.display = "block";
                        } else {
                            document.getElementById("availableDaysContainer").style.display = "none";
                        }

                        // Show fee summary
                        const fee = parseFloat(data.fee) || 0;
                        const tax = fee * 0.06;
                        const total = fee + tax;

                        document.getElementById("feeDisplay").textContent = fee.toFixed(2);
                        document.getElementById("taxDisplay").textContent = tax.toFixed(2);
                        document.getElementById("totalDisplay").textContent = total.toFixed(2);
                        document.getElementById("feeSummarySection").style.display = "block";

                        // Trigger slot update in case date was already picked
                        updateAvailableSlots();
                    }
                } catch (error) {
                    console.error("Error fetching doctor schedule:", error);
                }
            }

            function resetSlots() {
                slotSection.style.display = "none";
                slotsContainer.innerHTML = "";
                selectedTime = null;
                hiddenDateInput.value = "";
            }

            async function updateAvailableSlots() {
                const doctorId = doctorSelect.value;
                const dateVal = datePicker.value;

                if (!doctorId || !dateVal) {
                    resetSlots();
                    return;
                }

                // Day of week check
                const selectedDate = new Date(dateVal);
                const dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
                const selectedDayName = dayNames[selectedDate.getDay()];

                if (availableDays.length > 0 && !availableDays.includes(selectedDayName)) {
                    slotsContainer.innerHTML = `<span class="text-danger fw-bold"><i class="fas fa-exclamation-triangle"></i> This doctor is not available on ${selectedDayName}s. Available days: ${availableDays.join(", ")}</span>`;
                    slotSection.style.display = "block";
                    hiddenDateInput.value = "";
                    return;
                }

                try {
                    const response = await fetch(`/Patient/GetAvailableSlots?doctorId=${doctorId}&date=${dateVal}`);
                    if (response.ok) {
                        const slots = await response.json();
                        slotsContainer.innerHTML = "";
                        
                        if (slots && slots.length > 0) {
                            slots.forEach(slot => {
                                const btn = document.createElement("button");
                                btn.type = "button";
                                btn.className = "btn slot-btn";
                                btn.textContent = slot;
                                btn.dataset.time = slot;
                                
                                if (selectedTime === slot) {
                                    btn.classList.add("active");
                                }

                                btn.addEventListener("click", function () {
                                    document.querySelectorAll(".slot-btn").forEach(b => b.classList.remove("active"));
                                    btn.classList.add("active");
                                    selectedTime = slot;
                                    hiddenDateInput.value = `${dateVal}T${slot}:00`;
                                });

                                slotsContainer.appendChild(btn);
                            });
                        } else {
                            slotsContainer.innerHTML = '<span class="text-danger fw-bold">No available working hours found for this doctor on this day.</span>';
                        }
                        slotSection.style.display = "block";
                    }
                } catch (error) {
                    console.error("Error fetching slots:", error);
                }
            }

            doctorSelect.addEventListener("change", fetchDoctorSchedule);
            datePicker.addEventListener("change", updateAvailableSlots);

            // Initial check on load
            if (doctorSelect.value) {
                fetchDoctorSchedule().then(() => {
                    if (hiddenDateInput.value) {
                        const dt = new Date(hiddenDateInput.value);
                        if (!isNaN(dt.getTime())) {
                            const yyyy = dt.getFullYear();
                            const mm = String(dt.getMonth() + 1).padStart(2, '0');
                            const dd = String(dt.getDate()).padStart(2, '0');
                            datePicker.value = `${yyyy}-${mm}-${dd}`;
                            
                            const hh = String(dt.getHours()).padStart(2, '0');
                            const min = String(dt.getMinutes()).padStart(2, '0');
                            selectedTime = `${hh}:${min}`;
                            
                            updateAvailableSlots();
                        }
                    }
                });
            }
        });
    </script>
}