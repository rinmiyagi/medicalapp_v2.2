@model medicalapp.Models.ViewModels.ReceptionistBookAppointmentViewModel

@{
    ViewData["Title"] = "Book Referred Appointment - MediCloud";
    Layout = "_Layout";
}

<div class="booking-container">
    <div class="container">
        <h2>📅 Book Referred Appointment</h2>
        <p class="text-muted">
            <strong>Patient:</strong> @Model.PatientName <br />
            <strong>Doctor:</strong> @Model.DoctorName
        </p>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <div class="booking-card">
            <form asp-action="BookReferredAppointment" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="PatientId" />
                <input type="hidden" asp-for="DoctorId" />

                <div class="form-group">
                    <label asp-for="AppointmentDate"></label>
                    <input asp-for="AppointmentDate" class="form-control" type="datetime-local" />
                    <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                    <small class="text-muted">Please select a date and time for the patient.</small>
                </div>

                <div class="form-group">
                    <label asp-for="ReasonForVisit"></label>
                    <input asp-for="ReasonForVisit" class="form-control" placeholder="Reason for visit" />
                    <span asp-validation-for="ReasonForVisit" class="text-danger"></span>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-calendar-plus"></i> Book Appointment
                    </button>
                    <a href="@Url.Action("AllAppointments")" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .booking-container { padding: 40px 0; }
        .booking-container h2 { color: #003366; margin-bottom: 5px; }
        .text-muted { color: #666; }

        .booking-card {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            max-width: 600px;
            margin-top: 25px;
        }

        .form-group { margin-bottom: 15px; }

        .form-control {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
        }

        .form-control:focus { outline: none; border-color: #0056a7; }

        .form-actions {
            margin-top: 20px;
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .btn {
            padding: 10px 24px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            cursor: pointer;
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary { background: #0056a7; color: white; }
        .btn-primary:hover { background: #003d7a; }
        .btn-outline { background: transparent; color: #0056a7; border: 1px solid #0056a7; }
        .btn-outline:hover { background: #0056a7; color: white; }

        .alert {
            padding: 12px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
        .alert-danger { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }

        .text-danger { color: #dc3545; font-size: 0.9rem; }
        .text-muted { color: #666; }
    </style>
}