@model List<medicalapp.Models.Appointment>

@{
    ViewData["Title"] = "My Appointments - MediCloud";
    Layout = "_Layout";
    var currentStatus = ViewBag.CurrentStatus as string ?? "all";
}

<div class="appointments-container">
    <div class="container">
        <h2>📋 My Appointments</h2>
        <p class="text-muted">View and manage your appointments</p>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <!-- Filter Tabs -->
        <div class="filter-tabs">
            <a href="@Url.Action("Appointments", new { status = "all" })" class="filter-tab @(currentStatus == "all" ? "active" : "")">All</a>
            <a href="@Url.Action("Appointments", new { status = "pending" })" class="filter-tab @(currentStatus == "pending" ? "active" : "")">Pending</a>
            <a href="@Url.Action("Appointments", new { status = "confirmed" })" class="filter-tab @(currentStatus == "confirmed" ? "active" : "")">Confirmed</a>
            <a href="@Url.Action("Appointments", new { status = "inprogress" })" class="filter-tab @(currentStatus == "inprogress" ? "active" : "")">In Progress</a>
            <a href="@Url.Action("Appointments", new { status = "completed" })" class="filter-tab @(currentStatus == "completed" ? "active" : "")">Completed</a>
            <a href="@Url.Action("Appointments", new { status = "cancelled" })" class="filter-tab @(currentStatus == "cancelled" ? "active" : "")">Cancelled</a>
        </div>

        <!-- Appointment List -->
        @if (Model.Any())
        {
            <div class="appointment-list">
                @foreach (var appt in Model)
                {
                    <div class="appointment-card">
                        <div class="appointment-info">
                            @if (appt.ReasonForVisit != null && appt.ReasonForVisit.StartsWith("Health Screening:"))
                            {
                                <span class="badge-screening"><i class="fas fa-heartbeat"></i> Screening</span>
                            }
                            <span class="appt-date">@appt.AppointmentDate.ToString("dd MMM yyyy")</span>
                            <span class="appt-time">@appt.StartTime.ToString(@"hh\:mm")</span>
                            <span class="appt-patient">@appt.Patient?.User?.FirstName @appt.Patient?.User?.LastName</span>
                            <span class="appt-reason">@appt.ReasonForVisit</span>
                            <span class="status-badge @appt.Status.ToLower()">@appt.Status</span>
                        </div>
                        <div class="appointment-actions">
                            <a href="@Url.Action("AppointmentDetails", new { id = appt.Id })" class="btn btn-sm btn-outline">View</a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-calendar-check"></i>
                <p>No appointments found.</p>
            </div>
        }

        <div class="quick-actions">
            <a href="@Url.Action("Dashboard")" class="btn btn-primary">Back to Dashboard</a>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .appointments-container { padding: 40px 0; }
        .appointments-container h2 { color: #003366; margin-bottom: 5px; }
        .text-muted { color: #666; }

        .filter-tabs {
            display: flex;
            gap: 10px;
            margin: 20px 0 25px;
            flex-wrap: wrap;
        }

        .filter-tab {
            padding: 8px 18px;
            border-radius: 20px;
            background: #f4f6f9;
            color: #666;
            text-decoration: none;
            font-size: 0.9rem;
            transition: all 0.3s ease;
        }

        .filter-tab:hover { background: #e9ecef; }
        .filter-tab.active { background: #0056a7; color: white; }

        .appointment-card {
            background: white;
            padding: 12px 18px;
            border-radius: 8px;
            margin-bottom: 10px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 10px;
        }

        .appointment-info {
            display: flex;
            gap: 15px;
            align-items: center;
            flex-wrap: wrap;
        }

        .appt-date { font-weight: 600; color: #003366; }
        .appt-time { color: #333; }
        .appt-patient { color: #0056a7; font-weight: 500; }
        .appt-reason { color: #666; font-size: 0.9rem; }

        .status-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .status-badge.pending { background: #ffc107; color: #856404; }
        .status-badge.confirmed { background: #28a745; color: white; }
        .status-badge.inprogress { background: #17a2b8; color: white; }
        .status-badge.completed { background: #6c757d; color: white; }
        .status-badge.cancelled { background: #dc3545; color: white; }

        .btn-sm { padding: 4px 12px; font-size: 0.8rem; }
        .btn-outline { background: transparent; color: #0056a7; border: 1px solid #0056a7; border-radius: 6px; text-decoration: none; padding: 5px 12px; }
        .btn-outline:hover { background: #0056a7; color: white; }

        .empty-state {
            text-align: center;
            padding: 40px;
            background: #f8f9fa;
            border-radius: 10px;
            color: #666;
        }

        .empty-state i {
            font-size: 2.5rem;
            color: #0056a7;
            margin-bottom: 10px;
        }

        .quick-actions { margin-top: 30px; }
        .btn-primary { background: #0056a7; color: white; padding: 10px 24px; border-radius: 8px; text-decoration: none; }
        .btn-primary:hover { background: #003d7a; }

        .alert {
            padding: 12px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
        .alert-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }

        .badge-screening {
            background: #eef5fc;
            color: #0056a7;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 0.75rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            text-transform: uppercase;
            border: 1px solid #d0e3f5;
        }

        @@media (max-width: 768px) {
            .appointment-info {
                flex-direction: column;
                align-items: flex-start;
                gap: 5px;
            }
            .appointment-card {
                flex-direction: column;
                align-items: stretch;
            }
        }
    </style>
}