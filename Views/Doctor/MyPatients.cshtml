@model IEnumerable<medicalapp.Models.Patient>

@{
    ViewData["Title"] = "My Patients - MediCloud";
    Layout = "_Layout";
}

<div class="doctor-container">
    <div class="container">
        <div class="mb-4">
            <h2>👥 My Patients</h2>
            <p class="text-muted">List of patients with active appointments or accepted referrals.</p>
        </div>

        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" style="min-width: 700px;">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4 py-3 text-secondary" style="width: 25%;">Patient Name</th>
                                <th class="py-3 text-secondary" style="width: 15%;">IC / Passport</th>
                                <th class="py-3 text-secondary" style="width: 15%;">Gender</th>
                                <th class="py-3 text-secondary" style="width: 15%;">Date of Birth</th>
                                <th class="py-3 text-secondary" style="width: 15%;">Blood Type</th>
                                <th class="pe-4 py-3 text-end" style="width: 15%;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var patient in Model)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold text-dark">
                                            <div class="d-flex align-items-center gap-2">
                                                <i class="fas fa-user-circle text-primary fs-4"></i>
                                                <div>
                                                    <span class="d-block">@patient.User.FirstName @patient.User.LastName</span>
                                                    <span class="text-muted small fw-normal" style="font-size: 0.8rem;">@patient.User.Email</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="text-dark fw-semibold">@patient.User.ICNumber</span>
                                        </td>
                                        <td>
                                            <span class="text-muted">@patient.User.Gender</span>
                                        </td>
                                        <td>
                                            <span class="text-muted">@patient.User.DateOfBirth.ToString("dd MMM yyyy")</span>
                                        </td>
                                        <td>
                                            <span class="badge bg-light text-dark border px-2 py-1">
                                                @(string.IsNullOrEmpty(patient.BloodType) ? "Unknown" : patient.BloodType)
                                            </span>
                                        </td>
                                        <td class="pe-4 text-end">
                                            <a href="@Url.Action("PatientHistory", "Doctor", new { patientId = patient.Id })" class="btn btn-primary btn-sm rounded-pill px-3">
                                                <i class="fas fa-notes-medical me-1"></i> View EMR
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">
                                        <i class="fas fa-users-slash" style="font-size: 3.5rem; color: #ced4da; margin-bottom: 15px; display: block;"></i>
                                        <p class="mb-0 fw-bold">No Patients Found</p>
                                        <p class="text-muted small">You currently have no patient appointments or active referrals.</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <a href="@Url.Action("Dashboard")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .doctor-container { padding: 40px 0; }
        .doctor-container h2 { color: #003366; }
        .bg-light { background-color: #f8f9fa !important; }
        .table > :not(caption) > * > * { border-bottom-color: #f1f3f5; }
        .btn-primary {
            background-color: #0056a7;
            border-color: #0056a7;
        }
        .btn-primary:hover {
            background-color: #003d7a;
            border-color: #003d7a;
        }
    </style>
}
