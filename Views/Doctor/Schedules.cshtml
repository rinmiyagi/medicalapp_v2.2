@model IEnumerable<medicalapp.Models.Schedule>

@{
    ViewData["Title"] = "My Schedule - MediCloud";
    Layout = "_Layout";
}

<div class="doctor-container">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2>📅 My Weekly Schedule</h2>
                <p class="text-muted">Manage your weekly consulting hours grouped by day.</p>
            </div>
            <a href="@Url.Action("AddSchedule")" class="btn btn-primary">
                <i class="fas fa-plus"></i> Add Time Slot
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
            </div>
        }

        <div class="schedule-section mt-4">
            @if (Model != null && Model.Any())
            {
                <div class="row g-3">
                    @foreach (var group in Model.GroupBy(s => s.DayOfWeek).OrderBy(g => (int)g.Key))
                    {
                        <div class="col-12">
                            <div class="card shadow-sm border-0 rounded-3 card-day-schedule">
                                <div class="card-body p-4 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                                    <!-- Day Info -->
                                    <div class="d-flex align-items-center gap-3" style="min-width: 180px;">
                                        <i class="far fa-calendar-alt text-primary fs-3"></i>
                                        <div>
                                            <h4 class="mb-0 fw-bold text-dark">@group.Key</h4>
                                            <span class="text-muted small">@group.Count() registered slot(s)</span>
                                        </div>
                                    </div>
                                    
                                    <!-- Time Slots -->
                                    <div class="d-flex flex-wrap gap-2 flex-grow-1 justify-content-start justify-content-md-end">
                                        @foreach (var schedule in group.OrderBy(s => s.StartTime))
                                        {
                                            <div class="badge-slot d-inline-flex align-items-center gap-2 border rounded-pill px-3 py-2">
                                                <span class="text-dark fw-semibold" style="font-size: 0.95rem;">
                                                    <i class="far fa-clock text-muted me-1"></i>
                                                    @DateTime.Today.Add(schedule.StartTime).ToString("hh:mm tt") - 
                                                    @DateTime.Today.Add(schedule.EndTime).ToString("hh:mm tt")
                                                </span>
                                                <span class="text-muted small border-start ps-2" style="font-size: 0.8rem;">@schedule.SlotDuration min</span>
                                                
                                                <form asp-action="DeleteSchedule" method="post" class="delete-schedule-form m-0 d-inline-flex align-items-center">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@schedule.Id" />
                                                    <button type="submit" class="btn-close-slot" title="Delete slot">
                                                        <i class="fas fa-times-circle"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="card shadow-sm border-0 rounded-3 text-center py-5">
                    <div class="card-body">
                        <i class="far fa-calendar-times" style="font-size: 3.5rem; color: #ced4da; margin-bottom: 15px; display: block;"></i>
                        <h4 class="text-dark fw-bold mb-2">No Schedule Slot Registered</h4>
                        <p class="text-muted mb-0">Please click the "Add Time Slot" button above to configure your consulting hours.</p>
                    </div>
                </div>
            }
        </div>

        <div class="mt-4">
            <a href="@Url.Action("Dashboard")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .doctor-container { padding: 40px 0; }
        .doctor-container h2 { color: #003366; }
        
        .card-day-schedule {
            background: #fff;
            border: 1px solid #eef1f6 !important;
            transition: all 0.2s ease;
        }
        .card-day-schedule:hover {
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.05) !important;
            border-color: #0056a7-subtle !important;
        }

        .badge-slot {
            background-color: #f8f9fa;
            border-color: #dee2e6 !important;
            transition: all 0.2s ease;
        }
        .badge-slot:hover {
            border-color: rgba(0, 86, 167, 0.3) !important;
            background-color: #eef5fc;
        }

        .btn-close-slot {
            background: none;
            border: none;
            color: #adb5bd;
            padding: 0;
            cursor: pointer;
            transition: color 0.2s ease;
            font-size: 1.1rem;
            display: inline-flex;
            align-items: center;
            margin-left: 4px;
        }
        .btn-close-slot:hover {
            color: #dc3545;
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".delete-schedule-form").forEach(form => {
                form.addEventListener("submit", function (e) {
                    e.preventDefault();
                    showConfirm(
                        "Delete Time Slot",
                        "Are you sure you want to delete this schedule slot?",
                        function () {
                            form.submit();
                        }
                    );
                });
            });
        });
    </script>
}
